# ===========================================
# SUPABASE (Dashboard -> Settings -> API)
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ===========================================
# SERVIDOR
# ===========================================
PORT=3000

# ===========================================
# APIs DE VAGAS (cadastre-se para obter as chaves)
# ===========================================
# Adzuna - https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Jooble - https://jooble.org/api/about
JOOBLE_API_KEY=
# Reed - https://www.reed.co.uk/developers/jobseeker
REED_API_KEY=
# The Muse - https://www.themuse.com/developers/api/v2
MUSE_API_KEY=
# Findwork - https://findwork.dev/developers/
FINDWORK_API_KEY=

# ===========================================
# BANCO DE DADOS POSTGRES (AWS RDS - opcional)
# Usado por src/database/db.js e src/database/setup.js
# ===========================================
DB_HOST=your-db-host.rds.amazonaws.com
DB_PORT=5432
DB_NAME=your-database-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# ===========================================
# APIs GRATUITAS (sem chave necessaria)
# ===========================================
# RemoteOK, Arbeitnow, Jobicy, We Work Remotely, Himalayas
